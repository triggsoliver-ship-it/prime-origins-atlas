# Stripe — get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Public URL of the deployed site (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Where seller and inquiry emails are sent
ADMIN_EMAIL=oliver@primeorigins.org

# Resend (https://resend.com) — required to actually deliver inquiry + seller emails.
# Free tier covers 100 emails/day. Sign up, create an API key, paste here.
RESEND_API_KEY=re_replace_me

# Optional — once you've verified primeorigins.org in Resend, change this to a custom sender.
# Until then leave unset and we'll send from Resend's onboarding@resend.dev address.
# EMAIL_FROM="Prime Origins Atlas <noreply@primeorigins.org>"

# Vercel Blob — auto-set when you add a Blob store in Vercel (Storage → Create → Blob)
# Required for seller document uploads. If unset, uploads are recorded as metadata only.
BLOB_READ_WRITE_TOKEN=

# Optional — forward seller submissions as JSON to a webhook (Zapier, Make, Slack)
SELLER_WEBHOOK_URL=
